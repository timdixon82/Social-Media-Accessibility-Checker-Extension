{
  "name": "linkedin-accessibility-auditor",
  "private": true,
  "version": "1.2.0",
  "description": "Chrome extension: WCAG accessibility auditor for LinkedIn posts.",
  "license": "MIT",
  "author": "Tim Dixon",
  "scripts": {
    "build": "node scripts/generate-icons.mjs && webpack --config webpack.config.js",
    "watch": "webpack --config webpack.config.js --watch",
    "package": "npm run build && node scripts/package-extension.mjs",
    "postinstall": "node scripts/copy-models.mjs",
    "test": "playwright test",
    "test:a11y": "playwright test tests/accessibility/",
    "lint:js": "eslint src/",
    "lint:css": "stylelint --allow-empty-input 'src/**/*.css'",
    "lint:html": "htmlhint 'src/**/*.html'",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:html"
  },
  "dependencies": {
    "@gutenye/ocr-browser": "1.4.8",
    "jszip": "3.10.1",
    "onnxruntime-web": "1.26.0",
    "pdfmake": "0.2.23"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.3",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "copy-webpack-plugin": "14.0.0",
    "eslint": "10.4.1",
    "globals": "17.6.0",
    "htmlhint": "1.6.3",
    "stylelint": "16.19.1",
    "stylelint-config-standard": "38.0.0",
    "webpack": "5.106.2",
    "webpack-cli": "5.1.4"
  }
}
